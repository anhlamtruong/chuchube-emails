# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Supabase Storage ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=documents

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ─── Access Key Gate ──────────────────────────────────────────────────────
ACCESS_KEY_ENABLED=true
ACCESS_MASTER_KEY=change-me-to-a-random-string
# ADMIN_USER_ID is only used by Alembic migrations (019, 021) for seeding.
ADMIN_USER_ID=

# ─── SMTP (default sender for notifications) ─────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# ─── Sender Info (used in email templates) ────────────────────────────────
YOUR_NAME=
YOUR_PHONE=
YOUR_CITY_STATE=

# ─── CORS / Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Ollama / LLM ────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# ─── Bounce Detection ────────────────────────────────────────────────────
BOUNCE_CHECK_ENABLED=true
BOUNCE_CHECK_INTERVAL=300

# ─── Session ──────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SECONDS=86400
